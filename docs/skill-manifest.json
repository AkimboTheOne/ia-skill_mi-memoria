{
  "name": "mi-memoria",
  "version": "0.4.1",
  "maturity": "p4-stable",
  "command_metadata": {
    "ask": {"intent": "Detecta intención simple y genera preview de normalización.", "mutates": true, "requires_vault": false, "input_modes": ["texto-inline"], "outputs": ["mensaje", "output_path"], "artifacts": ["workspace/preview/*.md"], "constraints": ["No aplica al vault final automáticamente."], "examples": ["./bin/mi-memoria ask \"Normaliza esta nota\" --json"]},
    "explain": {"intent": "Describe el propósito operativo del runtime.", "mutates": false, "requires_vault": false, "input_modes": [], "outputs": ["message"], "artifacts": [], "constraints": ["Informativo."], "examples": ["./bin/mi-memoria explain --json"]},
    "context": {"intent": "Reporta contexto del runtime y vault configurado.", "mutates": false, "requires_vault": false, "input_modes": [], "outputs": ["runtime", "workspace", "vault"], "artifacts": [], "constraints": ["No valida escritura."], "examples": ["./bin/mi-memoria context --json"]},
    "capabilities": {"intent": "Expone contrato de capacidades y metadata LLM.", "mutates": false, "requires_vault": false, "input_modes": [], "outputs": ["commands", "command_metadata", "maturity"], "artifacts": ["docs/skill-manifest.json"], "constraints": ["Debe reflejar comandos implementados."], "examples": ["./bin/mi-memoria capabilities --json"]},
    "run normalize": {"intent": "Normaliza markdown a formato estándar en preview o write.", "mutates": true, "requires_vault": false, "input_modes": ["--input", "stdin"], "outputs": ["output_path", "validation"], "artifacts": ["workspace/preview/*.md", "vault/*.md"], "constraints": ["`--preview` y `--write` son excluyentes."], "examples": ["./bin/mi-memoria run normalize --input note.md --preview --json"]},
    "validate": {"intent": "Valida estructura y frontmatter de una nota.", "mutates": false, "requires_vault": false, "input_modes": ["--input"], "outputs": ["ok", "errors", "warnings"], "artifacts": [], "constraints": ["No corrige automáticamente."], "examples": ["./bin/mi-memoria validate --input note.md --json"]},
    "remember": {"intent": "Guarda memoria curada en vault o runtime (scope explícito).", "mutates": true, "requires_vault": true, "input_modes": ["--summary", "--input"], "outputs": ["output_path", "scope"], "artifacts": ["vault/memory/*.md", "memory/hot/*.md"], "constraints": ["Por defecto requiere vault."], "examples": ["./bin/mi-memoria remember --summary \"...\" --vault-path /path/to/vault --json"]},
    "apply": {"intent": "Aplica preview validado al destino final del vault.", "mutates": true, "requires_vault": true, "input_modes": ["--input"], "outputs": ["output_path", "proposed_vault_path"], "artifacts": ["vault/*/*.md"], "constraints": ["Solo acepta archivos dentro de workspace/preview."], "examples": ["./bin/mi-memoria apply --input workspace/preview/note.md --vault-path /path/to/vault --json"]},
    "template": {"intent": "Gestiona templates (list/show/generate/validate/apply/sync).", "mutates": true, "requires_vault": false, "input_modes": ["subcommands"], "outputs": ["template", "output_path", "artifacts"], "artifacts": ["workspace/preview/templates/*.md", "vault/templates/*.md"], "constraints": ["`apply` y `sync` requieren vault."], "examples": ["./bin/mi-memoria template list --json"]},
    "upgrade": {"intent": "Actualiza runtime con git pull ff-only.", "mutates": true, "requires_vault": false, "input_modes": [], "outputs": ["stdout", "stderr", "returncode"], "artifacts": [], "constraints": ["No ejecuta comandos arbitrarios."], "examples": ["./bin/mi-memoria upgrade --json"]},
    "capture": {"intent": "Captura notas rápidas en workspace/vault-workspace.", "mutates": true, "requires_vault": false, "input_modes": ["--text", "--input"], "outputs": ["output_path", "classification"], "artifacts": ["workspace/inbox/*.md"], "constraints": ["Destino limitado a workspace permitido."], "examples": ["./bin/mi-memoria capture --kind idea --text \"...\" --json"]},
    "daily": {"intent": "Gestiona nota diaria con append y resumen opcional.", "mutates": true, "requires_vault": false, "input_modes": ["--date", "--append"], "outputs": ["output_path", "summary"], "artifacts": ["workspace/daily/*.md", "vault/workspace/daily/*.md"], "constraints": ["No mueve notas automáticamente."], "examples": ["./bin/mi-memoria daily --append \"Nota\" --json"]},
    "decision": {"intent": "Registra/lista decisiones trazables.", "mutates": true, "requires_vault": false, "input_modes": ["subcommands"], "outputs": ["output_path", "items"], "artifacts": ["workspace/decisions/*.md"], "constraints": ["`decision_status` validado."], "examples": ["./bin/mi-memoria decision new --title \"...\" --json"]},
    "classify": {"intent": "Propone destino taxonómico sin mover archivo.", "mutates": false, "requires_vault": false, "input_modes": ["--input"], "outputs": ["proposed_destination", "alternatives"], "artifacts": [], "constraints": ["No ejecuta movimientos."], "examples": ["./bin/mi-memoria classify --input note.md --json"]},
    "review": {"intent": "Genera reporte de validación estructural.", "mutates": true, "requires_vault": false, "input_modes": ["--input", "--path"], "outputs": ["checks", "issues", "report_paths"], "artifacts": ["workspace/preview/*-review-report.md", "workspace/preview/*-review-report.json"], "constraints": ["No corrige archivos."], "examples": ["./bin/mi-memoria review --path workspace/inbox --json"]},
    "link": {"intent": "Sugiere wikilinks potenciales.", "mutates": false, "requires_vault": false, "input_modes": ["--input"], "outputs": ["suggested_links"], "artifacts": [], "constraints": ["Sin persistencia automática."], "examples": ["./bin/mi-memoria link --input note.md --preview --json"]},
    "summarize": {"intent": "Genera síntesis trazable de nota/carpeta.", "mutates": true, "requires_vault": false, "input_modes": ["--input", "--path"], "outputs": ["summary", "sources", "output_path"], "artifacts": ["workspace/preview/*-summary.md"], "constraints": ["Máximo 20 fuentes por ejecución."], "examples": ["./bin/mi-memoria summarize --path workspace/inbox --json"]},
    "index": {"intent": "Construye índice navegable y duplicados.", "mutates": true, "requires_vault": false, "input_modes": ["--path"], "outputs": ["totals", "duplicates", "output_path"], "artifacts": ["workspace/preview/*-index.md"], "constraints": ["No reubica notas."], "examples": ["./bin/mi-memoria index --path workspace/inbox --json"]},
    "timeline": {"intent": "Genera línea de tiempo de notas.", "mutates": true, "requires_vault": false, "input_modes": ["--path"], "outputs": ["events", "output_path"], "artifacts": ["workspace/preview/*-timeline.md"], "constraints": ["Marca fechas inferidas."], "examples": ["./bin/mi-memoria timeline --path workspace/inbox --json"]},
    "drift-detection": {"intent": "Detecta deriva de calidad/taxonomía.", "mutates": true, "requires_vault": false, "input_modes": ["--path"], "outputs": ["issues", "report_paths"], "artifacts": ["workspace/preview/*-drift-report.md", "workspace/preview/*-drift-report.json"], "constraints": ["No corrige automáticamente."], "examples": ["./bin/mi-memoria drift-detection --path workspace/inbox --json"]},
    "curate": {"intent": "Genera plan de curaduría sin mutaciones masivas.", "mutates": true, "requires_vault": false, "input_modes": ["--path"], "outputs": ["issues", "report_paths"], "artifacts": ["workspace/preview/*-curation-report.md", "workspace/preview/*-curation-report.json"], "constraints": ["No aplica acciones de curaduría."], "examples": ["./bin/mi-memoria curate --path workspace/inbox --json"]},
    "publish": {"intent": "Exporta conocimiento sin mutar fuentes.", "mutates": true, "requires_vault": false, "input_modes": ["--path", "--context-pack"], "outputs": ["output_path", "artifacts"], "artifacts": ["workspace/exports/*"], "constraints": ["En P4 solo soporta format=markdown."], "examples": ["./bin/mi-memoria publish --path workspace/inbox --format markdown --json"]},
    "archive": {"intent": "Archiva notas con control explícito preview/apply.", "mutates": true, "requires_vault": true, "input_modes": ["--input", "--preview", "--apply"], "outputs": ["plan", "output_path"], "artifacts": ["vault/40-archive/*.md"], "constraints": ["No sobrescribe destino existente."], "examples": ["./bin/mi-memoria archive --input 30-resources/a.md --preview --vault-path /path/to/vault --json"]},
    "query": {"intent": "Consulta contextual con evidencia e incertidumbre.", "mutates": false, "requires_vault": false, "input_modes": ["query", "--path"], "outputs": ["results", "evidence", "uncertainty"], "artifacts": [], "constraints": ["Sin evidencia suficiente retorna incertidumbre explícita."], "examples": ["./bin/mi-memoria query \"taxonomía\" --path . --json"]},
    "context-build": {"intent": "Construye context-pack reutilizable.", "mutates": true, "requires_vault": false, "input_modes": ["--path", "--topic"], "outputs": ["sources", "artifacts"], "artifacts": ["workspace/exports/*-context-pack.md", "workspace/exports/*-context-pack.json", "workspace/exports/*-source-map.json"], "constraints": ["Selección acotada por --max-files."], "examples": ["./bin/mi-memoria context-build --topic \"arquitectura\" --json"]},
    "session": {"intent": "Gestiona sesión temporal local.", "mutates": true, "requires_vault": false, "input_modes": ["subcommands"], "outputs": ["session", "context", "active_files"], "artifacts": ["tmp/sessions/*.json"], "constraints": ["No persiste memoria automáticamente."], "examples": ["./bin/mi-memoria session start --name refactor --json"]},
    "template sync": {"intent": "Sincroniza plantillas CORE faltantes en vault en modo seguro.", "mutates": true, "requires_vault": true, "input_modes": ["--vault-path"], "outputs": ["summary", "added", "outdated", "artifacts"], "artifacts": ["vault/templates/*.md", "workspace/preview/*-template-sync-report.md", "workspace/preview/*-template-sync-report.json"], "constraints": ["No sobrescribe plantillas existentes."], "examples": ["./bin/mi-memoria template sync --vault-path /path/to/vault --json"]}
  }
}
